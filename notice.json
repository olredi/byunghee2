
// lib/services/notice_service.dart
// 공지사항 / 업데이트 감지 서비스
//
// 동작:
//  - fetchNotice(): 원격 JSON URL에서 공지를 읽어온다 (네트워크 필요)
//  - 월 1회 자동 확인 + 사용자가 "온라인 확인" 수동 실행 가능
//  - 버전 비교로 업데이트 필요 여부 판단
//  - "이 공지 다시 안 보기"를 noticeId 기준으로 settings에 저장
//  - buildJson(): 관리자 메뉴에서 공지를 JSON 문자열로 생성 (GitHub 붙여넣기용)

import 'dart:convert';
import 'package:http/http.dart' as http;

import '../database/app_database.dart';
import '../models/app_notice.dart';

class NoticeService {
  final AppDatabase _appDb = AppDatabase.instance;

  // 관리자가 공지 JSON을 올려둔 원격 URL.
  // 기본값은 settings('notice_url')로 덮어쓸 수 있게 둔다.
  static const _defaultUrl =
      'https://raw.githubusercontent.com/olredi/byunghee2/main/notice.json';

  static const _kUrl          = 'notice_url';
  static const _kLastCheck    = 'notice_last_check';   // ISO8601
  static const _kDismissedId  = 'notice_dismissed_id'; // 다시 안 보기한 noticeId

  Future<String> getUrl() async =>
      (await _appDb.getSetting(_kUrl))?.trim().isNotEmpty == true
          ? (await _appDb.getSetting(_kUrl))!.trim()
          : _defaultUrl;

  Future<void> setUrl(String url) => _appDb.setSetting(_kUrl, url.trim());

  /// 원격 공지 조회. 실패 시 null.
  Future<AppNotice?> fetchNotice() async {
    try {
      final url = await getUrl();
      final resp = await http
          .get(Uri.parse(url))
          .timeout(const Duration(seconds: 10));
      if (resp.statusCode != 200) return null;
      final json = jsonDecode(utf8.decode(resp.bodyBytes)) as Map<String, dynamic>;
      await _appDb.setSetting(_kLastCheck, DateTime.now().toIso8601String());
      return AppNotice.fromJson(json);
    } catch (_) {
      return null;
    }
  }

  /// 월 1회 자동 확인 대상인지 (마지막 확인이 이번 달이 아니면 true)
  Future<bool> shouldAutoCheck() async {
    final last = await _appDb.getSetting(_kLastCheck);
    if (last == null || last.isEmpty) return true;
    final lastDate = DateTime.tryParse(last);
    if (lastDate == null) return true;
    final now = DateTime.now();
    return !(lastDate.year == now.year && lastDate.month == now.month);
  }

  /// 이 공지를 "다시 안 보기" 처리했는지
  Future<bool> isDismissed(String noticeId) async {
    if (noticeId.isEmpty) return false;
    final v = await _appDb.getSetting(_kDismissedId);
    return v == noticeId;
  }

  Future<void> dismiss(String noticeId) =>
      _appDb.setSetting(_kDismissedId, noticeId);

  /// 버전 비교: current < latest 이면 업데이트 필요
  /// "1.0.3" 형태의 점 구분 정수 비교
  bool isUpdateAvailable(String current, String latest) {
    if (latest.isEmpty) return false;
    final c = _parseVer(current);
    final l = _parseVer(latest);
    for (var i = 0; i < 3; i++) {
      if (l[i] > c[i]) return true;
      if (l[i] < c[i]) return false;
    }
    return false;
  }

  List<int> _parseVer(String v) {
    // "1.0.3+5" → [1,0,3]
    final core = v.split('+').first.trim();
    final parts = core.split('.');
    final nums = <int>[0, 0, 0];
    for (var i = 0; i < 3 && i < parts.length; i++) {
      nums[i] = int.tryParse(parts[i].replaceAll(RegExp(r'[^0-9]'), '')) ?? 0;
    }
    return nums;
  }

  /// 관리자 메뉴용: 공지 객체를 보기 좋은 JSON 문자열로 변환
  String buildJson(AppNotice notice) {
    const encoder = JsonEncoder.withIndent('  ');
    return encoder.convert(notice.toJson());
  }
}
